{
  "name": "mobile",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest",
    "cap:sync": "npx cap sync && bash scripts/setup-native.sh",
    "cap:setup": "bash scripts/setup-native.sh",
    "android": "vite build && npx cap sync android && bash scripts/setup-native.sh && npx cap run android",
    "android:staging": "VITE_API_BASE_URL=https://staging.deamap.es vite build && npx cap sync android && bash scripts/setup-native.sh && npx cap run android",
    "android:local": "vite build && npx cap sync android && bash scripts/setup-native.sh && npx cap run android",
    "android:live": "npx cap run android --livereload --external",
    "ios": "VITE_API_BASE_URL=https://deamap.es vite build && npx cap sync ios && bash scripts/setup-native.sh && npx cap run ios",
    "ios:staging": "VITE_API_BASE_URL=https://staging.deamap.es vite build && npx cap sync ios && bash scripts/setup-native.sh && npx cap run ios",
    "ios:local": "vite build && npx cap sync ios && bash scripts/setup-native.sh && npx cap run ios",
    "ios:live": "npx cap run ios --livereload --external",
    "android:open": "npx cap open android",
    "ios:open": "npx cap open ios",
    "assets:generate": "npx @capacitor/assets generate --android --ios --pwa"
  },
  "dependencies": {
    "@capacitor-firebase/crashlytics": "^8.1.0",
    "@capacitor-firebase/performance": "^8.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.1.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@capgo/capacitor-autofill-save-password": "^8.0.18",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "firebase": "^12.10.0",
    "ionicons": "^7.4.0",
    "leaflet": "^1.9.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "8.1.0",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.0.1",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.5.0",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "description": "DeaMap mobile app - Ionic React + Capacitor"
}
