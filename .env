# Default environment variables
# Override these in .env.local for local development
# Vercel will override with environment variables from dashboard

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dea_madrid?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google Maps API
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# AWS S3 for image storage
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
