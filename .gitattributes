# Auto detect text files and perform LF normalization
* text=auto

# Scripts should always use LF endings
*.sh text eol=lf

# SQL files should use LF endings
*.sql text eol=lf

# Source code
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documents
*.csv text eol=lf
