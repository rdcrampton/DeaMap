# Default environment variables
# Copy this file to .env for local development
# Vercel will override with environment variables from dashboard

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google Maps API
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# AWS Credentials (used for S3 and SES)
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# AWS S3 for image storage
AWS_S3_BUCKET_NAME="your-bucket-name"
AWS_S3_BUCKET="your-bucket-name"

# CDN Configuration (optional - if not set, falls back to S3 direct URLs)
# CloudFront distribution for faster image delivery
#CDN_BASE_URL="https://your-cloudfront-distribution.cloudfront.net"

# Import Recovery System
IMPORT_RECOVERY_ENABLED="true"
IMPORT_RECOVERY_AUTO_RESUME="true"
IMPORT_HEARTBEAT_INTERVAL_MS="30000"
IMPORT_HEARTBEAT_TIMEOUT_MS="300000"
IMPORT_CHECKPOINT_EVERY="10"
CRON_SECRET="your-cron-secret-hash"

# Email Service (AWS SES)
# Email sender address (must be verified in AWS SES)
EMAIL_FROM="noreply@yourdomain.com"

# Application URL (used for password reset links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
