# Database
# PostgreSQL connection string with PostGIS extension
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/dea_madrid?schema=public"

# NextAuth (if using authentication in the future)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Maps API
# Get your API key from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# AWS S3 (if using file storage)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="your-region"
# AWS_S3_BUCKET="your-bucket-name"
