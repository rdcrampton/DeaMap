# Default environment variables
# Copy this file to .env for local development
# Vercel will override with environment variables from dashboard

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google Maps API
# Server-side only (used for geocoding in batch jobs and API routes)
# Do NOT expose this key to the client for security reasons
GOOGLE_MAPS_API_KEY=""

# AWS Credentials (used for S3 and SES)
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# AWS S3 for image storage
AWS_S3_BUCKET_NAME="your-bucket-name"
AWS_S3_BUCKET="your-bucket-name"

# CDN Configuration (optional - if not set, falls back to S3 direct URLs)
# CloudFront distribution for faster image delivery
#CDN_BASE_URL="https://your-cloudfront-distribution.cloudfront.net"

# Import Recovery System
IMPORT_RECOVERY_ENABLED="true"
IMPORT_RECOVERY_AUTO_RESUME="true"
IMPORT_HEARTBEAT_INTERVAL_MS="30000"
IMPORT_HEARTBEAT_TIMEOUT_MS="300000"
IMPORT_CHECKPOINT_EVERY="10"
CRON_SECRET="your-cron-secret-hash"

# Import Processing Tuning (optional — sensible defaults if not set)
# Max duration per chunk in API route (ms). Default: 80000
#IMPORT_API_MAX_DURATION_MS="80000"
# Max duration per chunk in CRON (ms). Default: 45000
#IMPORT_CRON_MAX_DURATION_MS="45000"
# Safety timeout for CRON handler (ms). Default: 50000
#IMPORT_CRON_SAFETY_TIMEOUT_MS="50000"
# Timeout to detect orphaned jobs without heartbeat (ms). Default: 180000
#IMPORT_ORPHANED_JOB_TIMEOUT_MS="180000"
# Max jobs processed per CRON invocation. Default: 5
#IMPORT_CRON_MAX_JOBS="5"
# Records per processing chunk. Default: 50
#IMPORT_BATCH_SIZE="50"

# Email Service (AWS SES)
# Email sender address (must be verified in AWS SES)
EMAIL_FROM="noreply@yourdomain.com"

# Application URL (used for password reset links)
# OPTIONAL: Vercel automatically provides VERCEL_URL for all deployments (including branch previews)
# Only set this if you want to use a custom domain in production
# For local development, defaults to http://localhost:3000
# For Vercel deployments (production and preview), automatically uses https://<deployment-url>
#NEXT_PUBLIC_APP_URL="https://yourdomain.com"
