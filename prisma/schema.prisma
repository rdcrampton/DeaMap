generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm, postgis, unaccent, uuid_ossp(map: "uuid-ossp")]
}

// ============================================
// CORE - AED (Automated External Defibrillator) Information
// ============================================
model Aed {
  id                 String  @id @default(uuid()) @db.Uuid
  code               String? @unique
  provisional_number Int?
  name               String
  establishment_type String?

  // ⭐ GEOSPATIAL - Denormalized for fast proximity searches
  latitude              Float?
  longitude             Float?
  coordinates_precision String?
  geom                  Unsupported("geometry(Point, 4326)")? // PostGIS point

  // Origin and traceability
  source_origin      SourceOrigin @default(WEB_FORM)
  source_details     String?
  batch_job_id       String?      @db.Uuid
  external_reference String?

  // Notes (SIMPLIFIED - v2)
  public_notes       String? // Public information visible to all users
  internal_notes     Json? // Array of notes with metadata: [{text, author?, date?, type?}]
  rejection_reason   String? // Specific rejection reason for workflow
  requires_attention Boolean @default(false)

  // Verification and accessibility (ADDED)
  last_verified_at       DateTime? // Last physical verification date
  verification_method    String? // "field_visit", "phone_call", "email", "photo_verification"
  is_publicly_accessible Boolean   @default(true) // If accessible to general public
  installation_date      DateTime? // Physical installation date

  // General status
  status          AedStatus @default(DRAFT)
  status_metadata Json?
  published_at    DateTime?

  // ⭐ PUBLICATION SYSTEM - Controls what data is publicly visible
  publication_mode         PublicationMode @default(LOCATION_ONLY)
  publication_requested_at DateTime?
  publication_approved_at  DateTime?
  publication_approved_by  String?         @db.Uuid

  // ⭐ OWNERSHIP - Owner of the DEA (establishment owner)
  owner_user_id String? @db.Uuid

  // Creation sequence
  sequence Int @default(autoincrement())

  // Relationships
  location_id    String  @unique @db.Uuid
  responsible_id String? @db.Uuid
  schedule_id    String? @unique @db.Uuid

  location    AedLocation     @relation(fields: [location_id], references: [id])
  responsible AedResponsible? @relation(fields: [responsible_id], references: [id])
  schedule    AedSchedule?    @relation(fields: [schedule_id], references: [id])
  batch_job   BatchJob?       @relation("AedBatchJob", fields: [batch_job_id], references: [id])

  // External data source tracking (for syncs)
  data_source_id    String?             @db.Uuid
  data_source       ExternalDataSource? @relation("AedDataSource", fields: [data_source_id], references: [id])
  last_synced_at    DateTime? // Last sync with external source
  sync_content_hash String? // Hash to detect changes

  images              AedImage[]
  validations         AedValidation[]
  code_history        AedCodeHistory[]
  status_changes      AedStatusChange[]
  publication_history AedPublicationHistory[]
  assignments         AedOrganizationAssignment[]
  org_verifications   AedOrganizationVerification[]
  change_proposals    AedChangeProposal[]
  ownership_claims    AedOwnershipClaim[]
  field_changes       AedFieldChange[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by String?
  updated_by String?

  @@index([status])
  @@index([code])
  @@index([created_at])
  @@index([responsible_id])
  @@index([establishment_type])
  @@index([sequence])
  @@index([source_origin])
  @@index([batch_job_id])
  @@index([requires_attention])
  @@index([owner_user_id])
  @@index([data_source_id])
  @@index([external_reference])
  @@index([last_verified_at]) // NEW: For maintenance queries
  @@index([is_publicly_accessible, status]) // NEW: For public map filtering
  // ⭐ CRITICAL: Spatial index for proximity searches
  @@index([latitude, longitude], map: "idx_aeds_coordinates")
  @@index([status, latitude, longitude], map: "idx_aeds_published_coordinates")
  @@index([status, publication_mode], map: "idx_aeds_status_publication")
  // PostGIS spatial index (created via migration)
  @@map("aeds")
}

enum AedStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  INACTIVE
  REJECTED
}

enum PublicationMode {
  NONE // Not visible publicly
  LOCATION_ONLY // Only location data (city, postal code, district, street, number, floor)
  BASIC_INFO // Location + schedule + establishment type
  FULL // Full information: photos, responsible, contact, descriptions, etc.
}

enum SourceOrigin {
  WEB_FORM
  ADMIN_FORM
  EXCEL_IMPORT
  CSV_IMPORT
  EXTERNAL_API
  HEALTH_API
  FIRE_DEPARTMENT_API
  CIVIL_PROTECTION_API
  LEGACY_MIGRATION
  HOSPITAL_INTEGRATION
  MANUAL_UPDATE
  CITIZEN_REPORT
  FIELD_VERIFICATION
}

// ============================================
// STATUS CHANGE HISTORY
// ============================================
model AedStatusChange {
  id              String     @id @default(uuid()) @db.Uuid
  aed_id          String     @db.Uuid
  previous_status AedStatus?
  new_status      AedStatus
  reason          String?
  modified_by     String?
  notes           String?

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@index([aed_id, created_at])
  @@index([new_status])
  @@map("aed_status_changes")
}

// ============================================
// PUBLICATION HISTORY - Track publication mode changes
// ============================================
model AedPublicationHistory {
  id     String @id @default(uuid()) @db.Uuid
  aed_id String @db.Uuid

  previous_mode PublicationMode?
  new_mode      PublicationMode

  changed_by      String? @db.Uuid
  changed_by_role String?
  change_reason   String?

  // Approval workflow (optional)
  requires_approval Boolean   @default(false)
  approved_by       String?   @db.Uuid
  approved_at       DateTime?
  approval_notes    String?

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@index([aed_id, created_at])
  @@index([new_mode])
  @@index([changed_by])
  @@map("aed_publication_history")
}

// ============================================
// LEGACY BATCH IMPORTS - DEPRECATED
// Use BatchJob system instead (see bottom of file)
// ============================================
// Models ImportBatch, ImportError, ImportCheckpoint have been
// replaced by BatchJob, BatchJobError, BatchJobCheckpoint

// ============================================
// EXTERNAL DATA SOURCES - For API/JSON imports
// ============================================
model ExternalDataSource {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @unique
  description String?
  type        DataSourceType

  // Configuration (JSON with type-specific settings)
  config Json

  // Matching configuration
  matching_strategy  MatchingStrategy @default(HYBRID)
  matching_threshold Int              @default(75)

  // Scheduling
  is_active              Boolean       @default(true)
  sync_frequency         SyncFrequency @default(MANUAL)
  last_sync_at           DateTime?
  next_scheduled_sync_at DateTime?

  // Behavior
  auto_deactivate_missing Boolean  @default(false)
  auto_update_fields      String[] @default([])

  // Publication settings
  default_publication_mode PublicationMode @default(LOCATION_ONLY)

  // Scope
  source_origin SourceOrigin
  region_code   String // "MAD", "CAT", "AND", etc.

  // Relations
  managed_aeds Aed[]      @relation("AedDataSource")
  batch_jobs   BatchJob[] @relation("BatchJobDataSource")

  // Audit
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by String?  @db.Uuid

  @@index([is_active])
  @@index([sync_frequency])
  @@index([next_scheduled_sync_at])
  @@index([region_code])
  @@map("external_data_sources")
}

enum DataSourceType {
  CSV_FILE
  CKAN_API
  JSON_FILE
  REST_API
}

enum MatchingStrategy {
  BY_EXTERNAL_CODE
  BY_COORDINATES
  BY_ADDRESS
  HYBRID
}

enum SyncFrequency {
  MANUAL
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================
// LOCATION - Geographic information
// ============================================
model AedLocation {
  id String @id @default(uuid()) @db.Uuid

  // Address fields
  street_type   String?
  street_name   String?
  street_number String?
  postal_code   String?

  // Geographic information by city (no FK - multi-city support)
  city_name         String?
  city_code         String?
  district_code     String?
  district_name     String?
  neighborhood_code String?
  neighborhood_name String?

  // Access information (SIMPLIFIED - v2)
  floor               String? // Floor/level for filtering
  location_details    String? // Specific location details (combines additional_info + specific_location)
  access_instructions String? // How to access the AED

  aed                Aed?
  address_validation AedAddressValidation?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([postal_code])
  @@index([city_code, district_code])
  @@index([city_code, postal_code])
  @@map("aed_locations")
}

// ============================================
// SCHEDULE - Availability information
// ============================================
model AedSchedule {
  id                    String  @id @default(uuid()) @db.Uuid
  description           String?
  has_24h_surveillance  Boolean @default(false)
  has_restricted_access Boolean @default(false)

  // Structured schedules (HH:MM format)
  weekday_opening  String?
  weekday_closing  String?
  saturday_opening String?
  saturday_closing String?
  sunday_opening   String?
  sunday_closing   String?

  // Special days
  holidays_as_weekday Boolean @default(false)
  closed_on_holidays  Boolean @default(false)
  closed_in_august    Boolean @default(false)

  // Notes (SIMPLIFIED - v2)
  notes String? // General notes including exceptions

  aed Aed?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([has_24h_surveillance])
  @@map("aed_schedules")
}

// ============================================
// RESPONSIBLE - Contact information
// ============================================
model AedResponsible {
  id                String  @id @default(uuid()) @db.Uuid
  name              String
  email             String?
  phone             String?
  alternative_phone String?
  ownership         String?
  local_ownership   String?
  local_use         String?

  // Additional info
  organization String?
  position     String?
  department   String?

  // Notes (SIMPLIFIED - v2)
  notes Json? // Array of notes with metadata: [{text, author?, date?}]

  aeds Aed[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([organization])
  @@map("aed_responsibles")
}

// ============================================
// IMAGES - Image management
// ============================================
model AedImage {
  id     String       @id @default(uuid()) @db.Uuid
  aed_id String       @db.Uuid
  type   AedImageType
  order  Int          @default(1)

  // URLs
  original_url  String
  processed_url String?
  thumbnail_url String?

  // Metadata
  width      Int?
  height     Int?
  size_bytes Int?
  format     String?
  file_hash  String?

  // Verification status
  is_verified      Boolean   @default(false)
  verified_at      DateTime?
  verified_by      String?
  rejection_reason String?

  aed     Aed           @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  markers ImageMarker[]

  created_at DateTime @default(now())

  @@index([aed_id, type, order])
  @@index([is_verified])
  @@index([file_hash])
  @@map("aed_images")
}

enum AedImageType {
  FRONT
  LOCATION
  ACCESS
  SIGNAGE
  CONTEXT
  PLATE
}

model ImageMarker {
  id       String @id @default(uuid()) @db.Uuid
  image_id String @db.Uuid
  type     String

  // Normalized coordinates (0-1)
  start_x Float
  start_y Float
  end_x   Float?
  end_y   Float?

  // Style
  color     String  @default("#dc2626")
  thickness Int     @default(40)
  text      String?

  image      AedImage @relation(fields: [image_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@index([image_id])
  @@map("image_markers")
}

// ============================================
// VALIDATIONS - Verification system
// ============================================
model AedValidation {
  id     String           @id @default(uuid()) @db.Uuid
  aed_id String           @db.Uuid
  type   ValidationType
  status ValidationStatus @default(PENDING)

  // Process
  started_at   DateTime  @default(now())
  completed_at DateTime?
  verified_by  String?

  // Validation specific data
  data   Json?
  result Json?
  errors Json?

  // Metrics
  duration_ms Int?
  attempts    Int  @default(1)

  aed      Aed                 @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  sessions ValidationSession[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([aed_id, type])
  @@index([status, started_at])
  @@index([completed_at])
  @@index([type, status])
  @@map("aed_validations")
}

enum ValidationType {
  IMAGES
  ADDRESS
  SCHEDULE
  AVAILABILITY
  DUPLICATE
  MANUAL
}

enum ValidationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  REQUIRES_REVIEW
  ERROR
}

model ValidationSession {
  id            String  @id @default(uuid()) @db.Uuid
  validation_id String  @db.Uuid
  step          String
  step_data     Json?
  is_completed  Boolean @default(false)

  validation AedValidation @relation(fields: [validation_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([validation_id, step])
  @@map("validation_sessions")
}

// ============================================
// ADDRESS VALIDATION - Specific information
// ============================================
model AedAddressValidation {
  id          String @id @default(uuid()) @db.Uuid
  location_id String @unique @db.Uuid

  // Search results
  address_found   Boolean @default(false)
  match_level     Float?
  distance_meters Float?
  match_type      String?

  // Corrected coordinates (if applicable)
  suggested_latitude  Float?
  suggested_longitude Float?

  // Official address found (no FK - multi-city support)
  official_street_name       String?
  official_number            String?
  official_postal_code       String?
  official_city_name         String?
  official_city_code         String?
  official_district_code     String?
  official_district_name     String?
  official_neighborhood_code String?
  official_neighborhood_name String?

  // Suggested addresses
  suggestions Json @default("[]")

  // Diagnosis
  detected_problems   Json   @default("[]")
  recommended_actions Json   @default("[]")
  result_confidence   Float?

  // Process metadata
  strategies_used Json @default("[]")
  duration_ms     Int?
  api_calls_made  Int  @default(0)

  location AedLocation @relation(fields: [location_id], references: [id], onDelete: Cascade)

  processed_at DateTime @default(now())

  @@index([address_found])
  @@index([match_level])
  @@index([match_type])
  @@map("aed_address_validations")
}

// ============================================
// AED CODES - Management and history
// ============================================
model AedCodeHistory {
  id         String @id @default(uuid()) @db.Uuid
  aed_id     String @db.Uuid
  code       String @unique
  district   Int
  sequential Int

  // Status
  is_active     Boolean @default(true)
  change_reason String?
  changed_by    String?

  assigned_at    DateTime  @default(now())
  deactivated_at DateTime?

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  @@unique([district, sequential, is_active])
  @@index([aed_id, is_active])
  @@index([code])
  @@index([is_active])
  @@map("aed_code_history")
}

// ============================================
// AUDIT AND LOGS
// ============================================

model AuditLog {
  id         String  @id @default(uuid()) @db.Uuid
  table_name String
  record_id  String
  action     String
  user_id    String?
  ip_address String?
  user_agent String?

  // Change data
  data_before    Json?
  data_after     Json?
  changed_fields String[]

  created_at DateTime @default(now())

  @@index([table_name, record_id])
  @@index([user_id])
  @@index([created_at])
  @@index([action])
  @@map("audit_logs")
}

// ============================================
// METRICS AND MONITORING
// ============================================

model SystemMetric {
  id             String   @id @default(uuid()) @db.Uuid
  metric_name    String
  metric_value   Float
  metric_context Json?
  tags           String[] @default([])

  recorded_at DateTime @default(now())

  @@index([metric_name, recorded_at])
  @@index([recorded_at])
  @@map("system_metrics")
}

// ============================================
// AUTHENTICATION - User management
// ============================================

model User {
  id            String @id @default(uuid()) @db.Uuid
  email         String @unique
  password_hash String
  name          String

  // Profile
  role        UserRole @default(USER)
  is_active   Boolean  @default(true)
  is_verified Boolean  @default(false)

  // Metadata
  last_login_at       DateTime?
  verification_token  String?
  reset_token         String?
  reset_token_expires DateTime?

  // Relations
  organization_members OrganizationMember[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([is_active])
  @@map("users")
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

// ============================================
// LEGACY EXPORT BATCHES - DEPRECATED
// Use BatchJob system instead with AED_CSV_EXPORT or AED_JSON_EXPORT type
// ============================================

// ============================================
// ORGANIZATIONS - Groups that manage AEDs
// ============================================
model Organization {
  id   String           @id @default(uuid()) @db.Uuid
  type OrganizationType
  name String
  code String?          @unique // e.g. "PROTE_MADRID"

  // Contact & Location
  email       String?
  phone       String?
  website     String?
  description String?

  // ⭐ Geographic scope
  scope_type               OrgScopeType @default(CITY)
  city_code                String? // Municipality code
  city_name                String?
  district_codes           String[] // Array of district codes
  custom_scope_description String?

  // Settings
  require_approval   Boolean @default(true) // Requires external approval?
  approval_authority String? // e.g. "Ayuntamiento de Madrid"

  // Verification badge
  badge_name  String? // e.g. "Verificado por SAMUR"
  badge_icon  String? // Icon URL
  badge_color String? // Badge color

  // Hierarchy
  parent_org_id String?        @db.Uuid
  parent_org    Organization?  @relation("OrgHierarchy", fields: [parent_org_id], references: [id])
  child_orgs    Organization[] @relation("OrgHierarchy")

  is_active Boolean @default(true)

  members         OrganizationMember[]
  aed_assignments AedOrganizationAssignment[]
  verifications   AedOrganizationVerification[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by String?  @db.Uuid
  updated_by String?  @db.Uuid

  @@index([city_code])
  @@index([scope_type])
  @@index([type])
  @@index([is_active])
  @@map("organizations")
}

enum OrganizationType {
  CIVIL_PROTECTION // Protección Civil
  CERTIFIED_COMPANY // Empresa homologada/certificada
  VOLUNTEER_GROUP // Grupo de voluntarios
  MUNICIPALITY // Ayuntamiento
  HEALTH_SERVICE // Servicio de salud
  OWNER // Propietario del establecimiento
}

enum OrgScopeType {
  NATIONAL // National scope
  REGIONAL // Regional (Comunidad autónoma)
  CITY // Municipality/city
  DISTRICT // District within city
  CUSTOM // Custom area
}

// ============================================
// ORGANIZATION MEMBERS - Who belongs to what
// ============================================
model OrganizationMember {
  id              String @id @default(uuid()) @db.Uuid
  organization_id String @db.Uuid
  user_id         String @db.Uuid

  role OrgMemberRole @default(MEMBER)

  // Permissions
  can_verify         Boolean @default(true)
  can_edit           Boolean @default(false)
  can_approve        Boolean @default(false)
  can_manage_members Boolean @default(false)

  notes String?

  joined_at  DateTime @default(now())
  added_by   String?  @db.Uuid
  updated_by String?  @db.Uuid

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id])
  @@index([user_id])
  @@index([organization_id])
  @@map("organization_members")
}

enum OrgMemberRole {
  OWNER // Owner of the organization
  ADMIN // Administrator
  VERIFIER // Can perform verifications
  MEMBER // Basic member
  VIEWER // Read-only
}

// ============================================
// AED ORGANIZATION ASSIGNMENT - Who manages what AED
// ============================================
model AedOrganizationAssignment {
  id              String @id @default(uuid()) @db.Uuid
  aed_id          String @db.Uuid
  organization_id String @db.Uuid

  // Assignment type - Only ONE ACTIVE per type
  assignment_type AssignmentType @default(VERIFICATION)

  // Status
  status AssignmentStatus @default(ACTIVE)

  // Publication control per organization
  publication_mode      PublicationMode @default(LOCATION_ONLY)
  approved_for_full     Boolean         @default(false)
  approved_by_authority Boolean         @default(false) // Approved by municipality?
  approval_notes        String?

  // Assignment metadata
  assigned_by    String?   @db.Uuid
  assigned_at    DateTime  @default(now())
  revoked_at     DateTime?
  revoked_by     String?   @db.Uuid
  revoked_reason String?

  aed          Aed          @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([aed_id, assignment_type, status], name: "unique_active_assignment_per_type")
  @@index([aed_id, status])
  @@index([organization_id, status])
  @@index([assignment_type])
  @@map("aed_organization_assignments")
}

enum AssignmentType {
  CIVIL_PROTECTION // Only 1 active prote per AED
  CERTIFIED_COMPANY // Multiple companies can have active assignments
  OWNERSHIP // Only 1 owner
  MAINTENANCE // Only 1 maintenance company
  VERIFICATION // General verification
}

enum AssignmentStatus {
  ACTIVE
  REVOKED
  COMPLETED
  PENDING_APPROVAL
}

// ============================================
// AED ORGANIZATION VERIFICATION - Verification history
// ============================================
model AedOrganizationVerification {
  id              String @id @default(uuid()) @db.Uuid
  aed_id          String @db.Uuid
  organization_id String @db.Uuid

  verification_type VerificationType

  // Verification details
  verified_by String   @db.Uuid // User ID
  verified_at DateTime @default(now())

  // What was verified
  verified_address  Boolean @default(false)
  verified_schedule Boolean @default(false)
  verified_photos   Boolean @default(false)
  verified_access   Boolean @default(false)
  verified_signage  Boolean @default(false)

  // Certificate (for official reviews)
  certificate_number String?
  certificate_expiry DateTime?

  // Status - Latest verification tracking
  is_current    Boolean   @default(true)
  superseded_by String?   @db.Uuid // If there's a more recent verification
  superseded_at DateTime?

  notes String?

  aed          Aed          @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([aed_id, is_current])
  @@index([organization_id, verified_at])
  @@index([is_current])
  @@map("aed_organization_verifications")
}

enum VerificationType {
  INFORMAL // Informal verification (protes, volunteers)
  OFFICIAL // Official certified review
  SELF_REPORTED // Self-reported by owner
  FIELD_INSPECTION // Field inspection
}

// ============================================
// AED CHANGE PROPOSALS - For users without organizations
// ============================================
model AedChangeProposal {
  id     String @id @default(uuid()) @db.Uuid
  aed_id String @db.Uuid

  // Who proposed
  proposed_by String   @db.Uuid
  proposed_at DateTime @default(now())

  // What changes
  change_type      ProposalChangeType
  proposed_changes Json // Diff of proposed changes

  // Images/files attached
  attached_images String[] // URLs

  // Status
  status ProposalStatus @default(PENDING)

  // Review
  reviewed_by  String?   @db.Uuid
  reviewed_at  DateTime?
  review_notes String?

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  @@index([aed_id, status])
  @@index([proposed_by, status])
  @@index([status])
  @@map("aed_change_proposals")
}

enum ProposalChangeType {
  UPDATE_SCHEDULE // Propose schedule change
  UPDATE_LOCATION // Correct location
  ADD_PHOTOS // Add photos
  UPDATE_ACCESS // Update access info
  REPORT_ISSUE // Report issue (AED not working, etc)
}

enum ProposalStatus {
  PENDING // Pending review
  APPROVED // Approved (changes applied)
  REJECTED // Rejected
  NEEDS_MORE_INFO // Needs more information
}

// ============================================
// AED FIELD CHANGES - Granular audit trail
// ============================================
model AedFieldChange {
  id     String @id @default(uuid()) @db.Uuid
  aed_id String @db.Uuid

  // What changed
  field_name String // e.g. "schedule.weekday_opening"
  old_value  String?
  new_value  String?

  // Who & when
  changed_by     String   @db.Uuid
  changed_by_org String?  @db.Uuid // If belongs to an org
  changed_at     DateTime @default(now())

  // Source
  change_source ChangeSource

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  @@index([aed_id, changed_at])
  @@index([field_name])
  @@index([changed_by])
  @@map("aed_field_changes")
}

enum ChangeSource {
  WEB_UI // Manual change from UI
  API // Change via API
  IMPORT // Mass import
  VERIFICATION // During verification process
  PROPOSAL_APPROVAL // Proposal approval
}

// ============================================
// AED OWNERSHIP CLAIMS - Property claims
// ============================================
model AedOwnershipClaim {
  id     String @id @default(uuid()) @db.Uuid
  aed_id String @db.Uuid

  // Claimant
  claimed_by     String    @db.Uuid
  claimed_by_org String?   @db.Uuid // If claiming on behalf of org
  claim_type     ClaimType

  // Evidence
  evidence_description String
  evidence_files       String[] // Document URLs

  // Status
  status ClaimStatus @default(PENDING)

  // Review
  reviewed_by  String?   @db.Uuid
  reviewed_at  DateTime?
  review_notes String?

  created_at DateTime @default(now())

  aed Aed @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  @@index([aed_id, status])
  @@index([claimed_by])
  @@index([status])
  @@map("aed_ownership_claims")
}

enum ClaimType {
  ESTABLISHMENT_OWNER // Establishment owner
  EQUIPMENT_OWNER // DEA equipment owner
  AUTHORIZED_MANAGER // Authorized manager
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_VERIFICATION
}

// ============================================
// BATCH JOBS - Generic batch processing system
// ============================================
model BatchJob {
  id          String       @id @default(uuid()) @db.Uuid
  type        BatchJobType
  name        String
  description String?

  // Status and progress
  status BatchJobStatus @default(PENDING)

  // Configuration (JSON with type-specific settings)
  config Json

  // Progress tracking
  total_records      Int @default(0)
  processed_records  Int @default(0)
  successful_records Int @default(0)
  failed_records     Int @default(0)
  skipped_records    Int @default(0)
  warning_records    Int @default(0)
  current_chunk      Int @default(0)
  total_chunks       Int @default(0)

  // Result (populated after completion)
  result        Json?
  error_summary Json?

  // Timestamps
  started_at       DateTime?
  completed_at     DateTime?
  duration_seconds Int?

  // Recovery & Resume
  last_heartbeat        DateTime?
  last_checkpoint_index Int       @default(-1)
  resume_count          Int       @default(0)

  // Ownership and context
  created_by      String     @db.Uuid
  organization_id String?    @db.Uuid
  parent_job_id   String?    @db.Uuid
  parent_job      BatchJob?  @relation("JobHierarchy", fields: [parent_job_id], references: [id])
  child_jobs      BatchJob[] @relation("JobHierarchy")

  // External references
  data_source_id String?             @db.Uuid
  data_source    ExternalDataSource? @relation("BatchJobDataSource", fields: [data_source_id], references: [id])

  // Metadata and tags
  metadata Json?
  tags     String[] @default([])

  // Relations
  checkpoints  BatchJobCheckpoint[]
  errors       BatchJobError[]
  artifacts    BatchJobArtifact[]
  created_aeds Aed[]                @relation("AedBatchJob")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([created_by])
  @@index([organization_id])
  @@index([created_at])
  @@index([status, last_heartbeat])
  @@index([data_source_id])
  @@index([parent_job_id])
  @@map("batch_jobs")
}

enum BatchJobType {
  // Import operations
  AED_CSV_IMPORT
  AED_EXTERNAL_SYNC

  // Export operations
  AED_CSV_EXPORT
  AED_JSON_EXPORT

  // Bulk operations
  BULK_AED_UPDATE
  BULK_AED_DELETE
  BULK_STATUS_CHANGE

  // Verification operations
  BULK_VERIFICATION

  // Maintenance operations
  DATA_CLEANUP
  IMAGE_OPTIMIZATION

  // Report generation
  REPORT_GENERATION
}

enum BatchJobStatus {
  PENDING // Job created, waiting to start
  QUEUED // Job queued for processing
  IN_PROGRESS // Currently processing
  PAUSED // Paused by user, can be resumed
  WAITING // Waiting for next chunk invocation
  COMPLETED // Successfully completed
  COMPLETED_WITH_WARNINGS // Completed but with some warnings
  FAILED // Failed completely
  CANCELLED // Cancelled by user
  INTERRUPTED // Interrupted (timeout, crash), can be resumed
  RESUMING // Being resumed from interruption
}

// ============================================
// BATCH JOB CHECKPOINTS - For resumable processing
// ============================================
model BatchJobCheckpoint {
  id               String  @id @default(uuid()) @db.Uuid
  job_id           String  @db.Uuid
  record_index     Int
  record_reference String?
  record_hash      String?

  status             BatchCheckpointStatus
  error_message      String?
  processing_time_ms Int?

  // Context data
  record_data Json?

  job BatchJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@unique([job_id, record_index])
  @@index([job_id, status])
  @@index([record_hash])
  @@map("batch_job_checkpoints")
}

enum BatchCheckpointStatus {
  SUCCESS
  FAILED
  SKIPPED
}

// ============================================
// BATCH JOB ERRORS - Detailed error logging
// ============================================
model BatchJobError {
  id               String  @id @default(uuid()) @db.Uuid
  job_id           String  @db.Uuid
  record_index     Int?
  record_reference String?

  error_type    String
  error_message String
  severity      BatchErrorSeverity

  // Context
  row_data              Json?
  correction_suggestion String?

  job BatchJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@index([job_id])
  @@index([error_type])
  @@index([severity])
  @@map("batch_job_errors")
}

enum BatchErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================
// BATCH JOB ARTIFACTS - Output files and data
// ============================================
model BatchJobArtifact {
  id     String @id @default(uuid()) @db.Uuid
  job_id String @db.Uuid

  type        ArtifactType
  name        String
  description String?

  // File info
  mime_type String?
  file_size Int?
  file_url  String?
  file_hash String?

  // Data (for small inline data)
  data Json?

  // Expiration
  expires_at DateTime?

  job BatchJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@index([job_id])
  @@index([type])
  @@index([expires_at])
  @@map("batch_job_artifacts")
}

enum ArtifactType {
  FILE
  URL
  DATA
  REPORT
}
