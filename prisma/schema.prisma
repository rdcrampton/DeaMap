generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [postgis]
}

// ============================================
// CORE - AED (Automated External Defibrillator) Information
// ============================================
model Aed {
  id                        String                   @id @default(uuid()) @db.Uuid
  code                      String?                  @unique
  provisional_number        Int?
  name                      String
  establishment_type        String?

  // ⭐ GEOSPATIAL - Denormalized for fast proximity searches
  latitude                  Float?
  longitude                 Float?
  coordinates_precision     String?
  geom                      Unsupported("geometry(Point, 4326)")?  // PostGIS point

  // Origin and traceability
  source_origin             SourceOrigin             @default(WEB_FORM)
  source_details            String?
  import_batch_id           String?                  @db.Uuid
  external_reference        String?

  // Observations and notes (SIMPLIFIED)
  public_notes              String?  // NEW: Public information visible to all users
  internal_notes            String?  // Consolidated: includes origin_observations
  validation_notes          String?  // NEW: Renamed from validation_observations
  requires_attention        Boolean                  @default(false)
  attention_reason          String?
  rejection_reason          String?

  // DEPRECATED - Will be removed in future version (kept for migration)
  origin_observations       String?  /// @deprecated Merged into internal_notes
  validation_observations   String?  /// @deprecated Use validation_notes instead

  // Verification and accessibility (ADDED)
  last_verified_at          DateTime?  // Last physical verification date
  verification_method       String?    // "field_visit", "phone_call", "email", "photo_verification"
  is_publicly_accessible    Boolean    @default(true)  // If accessible to general public
  installation_date         DateTime?  // Physical installation date

  // General status
  status                    AedStatus                @default(DRAFT)
  status_metadata           Json?
  published_at              DateTime?

  // Creation sequence
  sequence                  Int                      @default(autoincrement())

  // Relationships
  location_id               String                   @unique @db.Uuid
  responsible_id            String?                  @db.Uuid
  schedule_id               String?                  @unique @db.Uuid

  location                  AedLocation              @relation(fields: [location_id], references: [id])
  responsible               AedResponsible?          @relation(fields: [responsible_id], references: [id])
  schedule                  AedSchedule?             @relation(fields: [schedule_id], references: [id])
  import_batch              ImportBatch?             @relation(fields: [import_batch_id], references: [id])
  images                    AedImage[]
  validations               AedValidation[]
  code_history              AedCodeHistory[]
  status_changes            AedStatusChange[]

  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @updatedAt
  created_by                String?
  updated_by                String?

  @@index([status])
  @@index([code])
  @@index([created_at])
  @@index([responsible_id])
  @@index([establishment_type])
  @@index([source_origin])
  @@index([import_batch_id])
  @@index([requires_attention])
  @@index([last_verified_at])  // NEW: For maintenance queries
  @@index([is_publicly_accessible, status])  // NEW: For public map filtering
  // ⭐ CRITICAL: Spatial index for proximity searches
  @@index([latitude, longitude], map: "idx_aeds_coordinates")
  @@index([status, latitude, longitude], map: "idx_aeds_published_coordinates")
  // PostGIS spatial index (created via migration)
  @@map("aeds")
}

enum AedStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  INACTIVE
  REJECTED
}

enum SourceOrigin {
  WEB_FORM
  ADMIN_FORM
  EXCEL_IMPORT
  CSV_IMPORT
  EXTERNAL_API
  HEALTH_API
  FIRE_DEPARTMENT_API
  CIVIL_PROTECTION_API
  LEGACY_MIGRATION
  HOSPITAL_INTEGRATION
  MANUAL_UPDATE
  CITIZEN_REPORT
  FIELD_VERIFICATION
}

// ============================================
// STATUS CHANGE HISTORY
// ============================================
model AedStatusChange {
  id                String      @id @default(uuid()) @db.Uuid
  aed_id            String      @db.Uuid
  previous_status   AedStatus?
  new_status        AedStatus
  reason            String?
  modified_by       String?
  notes             String?

  aed               Aed         @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  created_at        DateTime    @default(now())

  @@index([aed_id, created_at])
  @@index([new_status])
  @@map("aed_status_changes")
}

// ============================================
// BATCH IMPORTS - For mass uploads
// ============================================
model ImportBatch {
  id                    String                  @id @default(uuid()) @db.Uuid
  name                  String
  description           String?
  source_origin         SourceOrigin

  // Source file
  file_name             String?
  file_url              String?
  file_hash             String?
  file_size             Int?

  // Process statistics
  total_records         Int                     @default(0)
  successful_records    Int                     @default(0)
  failed_records        Int                     @default(0)
  warning_records       Int                     @default(0)

  // Status
  status                ImportStatus            @default(PENDING)
  completed_at          DateTime?
  duration_seconds      Int?

  // Recovery & Resume
  last_heartbeat        DateTime?
  last_checkpoint_index Int                     @default(0)
  resumed_count         Int                     @default(0)
  cancelled_manually    Boolean                 @default(false)

  // Metadata
  import_parameters     Json?
  error_summary         Json?
  detailed_log          String?

  // Audit
  imported_by           String
  ip_address            String?

  aeds                  Aed[]
  errors                ImportError[]
  checkpoints           ImportCheckpoint[]

  created_at            DateTime                @default(now())

  @@index([status])
  @@index([source_origin])
  @@index([created_at])
  @@index([imported_by])
  @@index([status, last_heartbeat])
  @@map("import_batches")
}

enum ImportStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  CANCELLED
  INTERRUPTED
  RESUMING
}

// ============================================
// IMPORT ERROR LOG
// ============================================
model ImportError {
  id                  String              @id @default(uuid()) @db.Uuid
  import_batch_id     String              @db.Uuid
  row_number          Int?
  record_reference    String?

  error_type          ImportErrorType
  affected_field      String?
  original_value      String?
  error_message       String
  severity            ErrorSeverity

  // Context
  row_data            Json?
  correction_suggestion String?

  import_batch        ImportBatch         @relation(fields: [import_batch_id], references: [id], onDelete: Cascade)

  created_at          DateTime            @default(now())

  @@index([import_batch_id])
  @@index([error_type])
  @@index([severity])
  @@map("import_errors")
}

enum ImportErrorType {
  VALIDATION
  FORMAT
  DUPLICATE_DATA
  MISSING_DATA
  INVALID_DATA
  RELATION_NOT_FOUND
  INVALID_COORDINATES
  ADDRESS_NOT_FOUND
  SYSTEM_ERROR
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================
// IMPORT CHECKPOINTS - For resumable imports
// ============================================
model ImportCheckpoint {
  id                  String              @id @default(uuid()) @db.Uuid
  import_batch_id     String              @db.Uuid
  record_index        Int
  record_reference    String?
  record_hash         String?

  status              CheckpointStatus
  error_message       String?
  processing_time_ms  Int?

  // Context data
  record_data         Json?

  import_batch        ImportBatch         @relation(fields: [import_batch_id], references: [id], onDelete: Cascade)

  created_at          DateTime            @default(now())

  @@unique([import_batch_id, record_index])
  @@index([import_batch_id, status])
  @@index([record_hash])
  @@map("import_checkpoints")
}

enum CheckpointStatus {
  SUCCESS
  FAILED
  SKIPPED
}

// ============================================
// LOCATION - Geographic information
// ============================================
model AedLocation {
  id                      String                      @id @default(uuid()) @db.Uuid

  // Original address from form
  street_type             String?
  street_name             String?
  street_number           String?
  additional_info         String?
  postal_code             String?

  // Original coordinates
  latitude                Float?
  longitude               Float?
  coordinates_precision   String?

  // Geographic information by city (no FK - multi-city support)
  city_name               String?
  city_code               String?
  district_code           String?
  district_name           String?
  neighborhood_code       String?
  neighborhood_name       String?

  // Access information (SIMPLIFIED)
  floor                   String?
  specific_location       String?
  access_instructions     String?  // NEW: Combines access_description + visible_references + access_warnings
  public_notes            String?  // NEW: Combines location_observations + general public info

  // DEPRECATED - Will be removed in future version (kept for migration)
  access_description      String?  /// @deprecated Use access_instructions instead
  visible_references      String?  /// @deprecated Use access_instructions instead
  access_warnings         String?  /// @deprecated Use access_instructions instead
  location_observations   String?  /// @deprecated Use public_notes instead

  aed                     Aed?
  address_validation      AedAddressValidation?

  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt

  @@index([postal_code])
  @@index([latitude, longitude], map: "idx_location_spatial")
  @@index([city_code, district_code])
  @@index([city_code, postal_code])  // NEW: For city-specific searches
  @@map("aed_locations")
}

// ============================================
// SCHEDULE - Availability information
// ============================================
model AedSchedule {
  id                      String    @id @default(uuid()) @db.Uuid
  description             String?
  has_24h_surveillance    Boolean   @default(false)
  has_restricted_access   Boolean   @default(false)

  // Structured schedules (HH:MM format)
  weekday_opening         String?
  weekday_closing         String?
  saturday_opening        String?
  saturday_closing        String?
  sunday_opening          String?
  sunday_closing          String?

  // Special days
  holidays_as_weekday     Boolean   @default(false)
  closed_on_holidays      Boolean   @default(false)
  closed_in_august        Boolean   @default(false)

  // Observations
  observations            String?
  schedule_exceptions     String?
  access_instructions     String?

  aed                     Aed?

  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@index([has_24h_surveillance])
  @@map("aed_schedules")
}

// ============================================
// RESPONSIBLE - Contact information
// ============================================
model AedResponsible {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  email             String?
  phone             String?
  alternative_phone String?
  ownership         String?
  local_ownership   String?
  local_use         String?

  // Additional info
  organization      String?
  position          String?
  department        String?

  // Observations
  observations      String?
  contact_notes     String?

  aeds              Aed[]

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([organization])
  @@map("aed_responsibles")
}

// ============================================
// IMAGES - Image management
// ============================================
model AedImage {
  id                  String            @id @default(uuid()) @db.Uuid
  aed_id              String            @db.Uuid
  type                AedImageType
  order               Int               @default(1)

  // URLs
  original_url        String
  processed_url       String?
  thumbnail_url       String?

  // Metadata
  width               Int?
  height              Int?
  size_bytes          Int?
  format              String?
  file_hash           String?

  // Verification status
  is_verified         Boolean           @default(false)
  verified_at         DateTime?
  verified_by         String?
  rejection_reason    String?

  aed                 Aed               @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  markers             ImageMarker[]

  created_at          DateTime          @default(now())

  @@index([aed_id, type, order])
  @@index([is_verified])
  @@index([file_hash])
  @@map("aed_images")
}

enum AedImageType {
  FRONT
  LOCATION
  ACCESS
  SIGNAGE
  CONTEXT
  PLATE
}

model ImageMarker {
  id          String      @id @default(uuid()) @db.Uuid
  image_id    String      @db.Uuid
  type        String

  // Normalized coordinates (0-1)
  start_x     Float
  start_y     Float
  end_x       Float?
  end_y       Float?

  // Style
  color       String      @default("#dc2626")
  thickness   Int         @default(40)
  text        String?

  image       AedImage    @relation(fields: [image_id], references: [id], onDelete: Cascade)
  created_at  DateTime    @default(now())

  @@index([image_id])
  @@map("image_markers")
}

// ============================================
// VALIDATIONS - Verification system
// ============================================
model AedValidation {
  id                  String              @id @default(uuid()) @db.Uuid
  aed_id              String              @db.Uuid
  type                ValidationType
  status              ValidationStatus    @default(PENDING)

  // Process
  started_at          DateTime            @default(now())
  completed_at        DateTime?
  verified_by         String?

  // Validation specific data
  data                Json?
  result              Json?
  errors              Json?

  // Metrics
  duration_ms         Int?
  attempts            Int                 @default(1)

  aed                 Aed                 @relation(fields: [aed_id], references: [id], onDelete: Cascade)
  sessions            ValidationSession[]

  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  @@index([aed_id, type])
  @@index([status, started_at])
  @@index([completed_at])
  @@index([type, status])
  @@map("aed_validations")
}

enum ValidationType {
  IMAGES
  ADDRESS
  SCHEDULE
  AVAILABILITY
  DUPLICATE
  MANUAL
}

enum ValidationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  REQUIRES_REVIEW
  ERROR
}

model ValidationSession {
  id                String            @id @default(uuid()) @db.Uuid
  validation_id     String            @db.Uuid
  step              String
  step_data         Json?
  is_completed      Boolean           @default(false)

  validation        AedValidation     @relation(fields: [validation_id], references: [id], onDelete: Cascade)

  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  @@index([validation_id, step])
  @@map("validation_sessions")
}

// ============================================
// ADDRESS VALIDATION - Specific information
// ============================================
model AedAddressValidation {
  id                        String          @id @default(uuid()) @db.Uuid
  location_id               String          @unique @db.Uuid

  // Search results
  address_found             Boolean         @default(false)
  match_level               Float?
  distance_meters           Float?
  match_type                String?

  // Corrected coordinates (if applicable)
  suggested_latitude        Float?
  suggested_longitude       Float?

  // Official address found (no FK - multi-city support)
  official_street_name      String?
  official_number           String?
  official_postal_code      String?
  official_city_name        String?
  official_city_code        String?
  official_district_code    String?
  official_district_name    String?
  official_neighborhood_code String?
  official_neighborhood_name String?

  // Suggested addresses
  suggestions               Json            @default("[]")

  // Diagnosis
  detected_problems         Json            @default("[]")
  recommended_actions       Json            @default("[]")
  result_confidence         Float?

  // Process metadata
  strategies_used           Json            @default("[]")
  duration_ms               Int?
  api_calls_made            Int             @default(0)

  location                  AedLocation     @relation(fields: [location_id], references: [id], onDelete: Cascade)

  processed_at              DateTime        @default(now())

  @@index([address_found])
  @@index([match_level])
  @@index([match_type])
  @@map("aed_address_validations")
}

// ============================================
// AED CODES - Management and history
// ============================================
model AedCodeHistory {
  id                String    @id @default(uuid()) @db.Uuid
  aed_id            String    @db.Uuid
  code              String    @unique
  district          Int
  sequential        Int

  // Status
  is_active         Boolean   @default(true)
  change_reason     String?
  changed_by        String?

  assigned_at       DateTime  @default(now())
  deactivated_at    DateTime?

  aed               Aed       @relation(fields: [aed_id], references: [id], onDelete: Cascade)

  @@unique([district, sequential, is_active])
  @@index([aed_id, is_active])
  @@index([code])
  @@index([is_active])
  @@map("aed_code_history")
}

// ============================================
// AUDIT AND LOGS
// ============================================

model AuditLog {
  id              String    @id @default(uuid()) @db.Uuid
  table_name      String
  record_id       String
  action          String
  user_id         String?
  ip_address      String?
  user_agent      String?

  // Change data
  data_before     Json?
  data_after      Json?
  changed_fields  String[]

  created_at      DateTime  @default(now())

  @@index([table_name, record_id])
  @@index([user_id])
  @@index([created_at])
  @@index([action])
  @@map("audit_logs")
}

// ============================================
// METRICS AND MONITORING
// ============================================

model SystemMetric {
  id              String    @id @default(uuid()) @db.Uuid
  metric_name     String
  metric_value    Float
  metric_context  Json?
  tags            String[]  @default([])

  recorded_at     DateTime  @default(now())

  @@index([metric_name, recorded_at])
  @@index([recorded_at])
  @@map("system_metrics")
}

// ============================================
// AUTHENTICATION - User management
// ============================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  password_hash     String
  name              String

  // Profile
  role              UserRole  @default(USER)
  is_active         Boolean   @default(true)
  is_verified       Boolean   @default(false)

  // Metadata
  last_login_at     DateTime?
  verification_token String?
  reset_token       String?
  reset_token_expires DateTime?

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([is_active])
  @@map("users")
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
}

// ============================================
// EXPORT BATCHES - For CSV exports
// ============================================
model ExportBatch {
  id                    String                  @id @default(uuid()) @db.Uuid
  name                  String
  description           String?

  // Filters applied
  filters               Json?                   // Stores status[], sourceOrigin, importBatchId, cityName

  // Export file
  file_name             String?
  file_url              String?                 // S3 URL when ready
  file_size             Int?
  file_hash             String?

  // Process statistics
  total_records         Int                     @default(0)
  successful_records    Int                     @default(0)
  failed_records        Int                     @default(0)

  // Status
  status                ExportStatus            @default(PENDING)
  started_at            DateTime?
  completed_at          DateTime?
  duration_seconds      Int?

  // Error handling
  error_message         String?
  error_details         Json?

  // Audit
  exported_by           String                  @db.Uuid
  ip_address            String?

  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt

  @@index([status])
  @@index([created_at])
  @@index([exported_by])
  @@index([status, created_at])
  @@map("export_batches")
}

enum ExportStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}
